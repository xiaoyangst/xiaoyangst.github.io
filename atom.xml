&lt;head&gt;
    &lt;title&gt;打字效果(wo.wap.sg)&lt;/title&gt;
    &lt;script language=&quot;javascript&quot;&gt;
    &lt;!--
    text = &quot;我用奔跑告诉你，我不会回头~~&quot;;
    i = 0;

    function type() {
        if(i &lt; text.length) {
            var str = text.substr(0, i);
            txt.innerHTML = str + &quot;_&quot;;
            i++;
            setTimeout(type, 300);
        } else {
            txt.innerHTML = text; // 显示完整文本，不带下划线
        }
    }
    //--&gt;
    &lt;/script&gt;
&lt;/head&gt;

&lt;body onLoad=&quot;type()&quot;&gt;
    &lt;div id=&quot;txt&quot;&gt;&lt;/div&gt;
&lt;/body&gt;

